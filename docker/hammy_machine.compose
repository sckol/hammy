services:
  hammy:
    privileged: true
    image: sckol/hammy:XXX
    command: "YYY"
    environment:
      - S3_ACCESS_KEY=AAA
      - S3_SECRET_KEY=SSS
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 1
              capabilities: [gpu]
